# Copy to /etc/flagpole.env and tighten permissions (chmod 600).
# systemd loads this via EnvironmentFile= in systemd/flagpole.service.

TRUTHSOCIAL_USERNAME=your_truth_social_username
TRUTHSOCIAL_PASSWORD=your_truth_social_password
# TRUTHSOCIAL_TOKEN=alternative_bearer_token

TRUTH_HANDLE=realdonaldtrump
ARDUINO_PORT=/dev/ttyACM0
POLL_INTERVAL=300
LOG_LEVEL=INFO
